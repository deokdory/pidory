[discord]
guild_id = 123456789          # dev 서버 ID (prod와 같거나 별도)
owner_id = 987654321          # 소유자 Discord ID
token_env = "PIDORY_DEV_DISCORD_TOKEN"  # prod와 다른 환경변수 사용

[claude]
binary_path = "claude"
default_disallowed_tools = []
subprocess_timeout_secs = 600
max_sessions = 5              # dev는 낮게

# [database] path is DEPRECATED — DATABASE_URL env is the authoritative source.
# Keep this section for backwards compatibility only.
# Set DATABASE_URL as an env variable for dev: export DATABASE_URL=postgres://pidory:<pw>@localhost/pidory
[database]
path = "pidory-dev.db"        # deprecated, ignored

[response]
max_chunk_length = 1900
max_chunks = 10
