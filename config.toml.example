# language = "ko"                # 봇 메시지 언어: "ko" (default) | "en"

[discord]
guild_id = 123456789          # 전용 서버 ID
owner_id = 987654321          # 소유자 Discord ID
# token은 환경변수 PIDORY_DISCORD_TOKEN으로 설정
# notification_channel_id = 123456789  # rate limit 알림을 보낼 채널 ID

[claude]
binary_path = "claude"        # claude CLI 경로
default_disallowed_tools = [] # 기본 차단 도구 목록
subprocess_timeout_secs = 600 # 10분
max_sessions = 10             # 동시 세션 상한
idle_timeout_secs = 7200      # 유휴 세션 타임아웃 (초), 0 to disable

[database]
path = "pidory.db"            # SQLite DB 경로

[response]
max_chunk_length = 1900       # Discord 2000자 여유분
max_chunks = 10               # 초과 시 파일 첨부

# [ratelimit]
# update_interval_secs = 60                   # presence 업데이트 주기 (초)
# alert_thresholds = [50, 80]                 # 5h rate limit 경고 임계값 (%)

# [attachment]
# max_file_size_mb = 25         # 파일 1개 최대 크기 (MB) [기본: 25 / Nitro: 500 / Nitro Basic: 50]
# max_aggregate_size_mb = 50    # 메시지당 첨부파일 총 크기 합계 (MB) [기본: 50]
# download_timeout_secs = 30    # 다운로드 타임아웃 (초) [기본: 30 / 대용량(500MB)은 300 이상 권장]
